  "shortcuts": [
    {
      "name": "Create Material",
      "short_name": "New Material",
      "description": "Create a new material passport",
      "url": "/materials/new",
      "icons": [{ "src": "/icons/shortcut-material.png", "sizes": "96x96" }]
    },
    {
      "name": "Scan QR",
      "short_name": "Scan",
      "description": "Scan QR code for handshake",
      "url": "/handshakes/scan",
      "icons": [{ "src": "/icons/shortcut-scan.png", "sizes": "96x96" }]
    },
    {
      "name": "View Scores",
      "short_name": "Scores",
      "description": "View credit scores",
      "url": "/scores",
      "icons": [{ "src": "/icons/shortcut-scores.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {
          "name": "documents",
          "accept": ["image/*", "application/pdf"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+btrace",
      "url": "/open?url=%s"
    }
  ]
}
