```gitignore
# Dependencies
node_modules/
.pnpm-store/
.yarn/
yarn.lock
package-lock.json

# Build outputs
dist/
build/
*.tsbuildinfo
.next/
.nuxt/

# Environment variables
.env
.env.local
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE specific
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Rust build artifacts (for backend)
target/
Cargo.lock

# Coverage reports
coverage/
*.lcov
*.profdata
*.coverage

# Temporary files
*.tmp
*.temp
.DS_Store
```